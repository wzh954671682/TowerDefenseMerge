# This .gitignore file is based on the Unity-specific gitignore template.
# It helps to exclude generated files and temporary data from version control.

# Unity generated files and folders
Library/
Temp/
Obj/
Build/
Builds/
Logs/
MemoryCaptures/

# Visual Studio cache directory
.vs/

# Autogenerated VS/MD/Consulo solution and project files
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.metaproj
*.gh

# Visual Studio Code files
.vscode/

# Rider files
.idea/

# Unity Package Manager (UPM) files
Packages/manifest.json
Packages/manifest.json.meta
Packages/packages-lock.json

# Cache files
.DS_Store

# MacOS specific files
*.DS_Store

# OSX folder for tests
/Assets/Tests/

# Generated assets
Assets/AssetStoreTools

# Unity specific files
*.orig
*.bak
*.rej
*.patch

# Optional: Assets you don't want to commit
# You can uncomment specific lines or add your own patterns here
# Assets/YourExternalAssets/

# User-specific files
# If you have any files that are specific to your local setup and should not be shared,
# you can add them here. For example:
# LocalSettings.asset

# Editor settings, but usually committed for consistency
# ProjectSettings/
# Assets/Presets/

# Asset bundle cache
AssetBundles/

# Crash reports
CrashReports/

# Custom Packages (if not managed by UPM)
# e.g., Assets/MyCustomPackage/